# Core
SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=0
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-render-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://your-render-app.onrender.com
SITE_URL=https://yourdomain.com
TIME_ZONE=Africa/Kigali

# Database - use PostgreSQL in production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Email - use Gmail app password, Brevo, Mailgun, SendGrid, or Resend SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=SMS Suite <your-email@gmail.com>
SERVER_EMAIL=SMS Suite <your-email@gmail.com>

# HTTPS/security. Enable after domain HTTPS works.
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=0
LOG_LEVEL=INFO
